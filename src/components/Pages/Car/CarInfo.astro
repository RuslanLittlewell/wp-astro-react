---
import { Separator } from "@radix-ui/react-dropdown-menu";

const { fields, car, options } = Astro.props;
const { car_info } = fields.car;


---

<div
  class="text-denim-900 w-full h-auto lg:h-[400px] grid grid-cols-1 lg:grid-cols-[40%_1fr] gap-3 shadow-md bg-denim-700/60 rounded-2xl p-5"
>
  <div class="space-y-2">
    <div class="flex gap-1 items-center justify-between">
      <span class="bg-denim-800 text-white px-3 py-2 rounded-2xl font-thin"
        >Количество посадочных мест:</span
      >
      <span class="px-3 py-2 rounded-2xl">{car_info.seats}</span>
    </div>
    <Separator className="h-px bg-white/50" />
    <div class="flex gap-1 items-center justify-between">
      <span class="bg-denim-800 text-white px-3 py-2 rounded-2xl font-thin"
        >Объем двигателя:</span
      >
      <span class="px-3 py-2 rounded-2xl">{car_info.engine}</span>
    </div>
    <Separator className="h-px bg-white/50" />
    <div class="flex gap-1 items-center justify-between">
      <span class="bg-denim-800 text-white px-3 py-2 rounded-2xl font-thin"
        >Расход топлива:</span
      >
      <span class="px-3 py-2 rounded-2xl">{car_info.fuel_consumption}</span>
    </div>
    <Separator className="h-px bg-white/50" />
    <div class="flex gap-1 items-center justify-between">
      <span class="bg-denim-800 text-white px-3 py-2 rounded-2xl font-thin"
        >Коробка передач:</span
      >
      <span class="px-3 py-2 rounded-2xl">{car_info.transmission}</span>
    </div>
    <Separator className="h-px bg-white/50" />
  </div>
  <div class="flex flex-col gap-3 md:border-l md:border-white/50 
           prose-ul:my-4 prose-ul:pl-5 prose-li:my-1
         prose-li:marker:text-denim-300
         [&_ul]:list-disc [&_ul]:pl-5
         [&_ul_ul]:list-[circle] [&_ul_ul]:pl-5
         [&_ul_ul_ul]:list-[square] [&_ul_ul_ul]:pl-5
         [&_ol]:list-decimal [&_ol]:pl-5
         [&_ol_ol]:list-[lower-alpha] [&_ol_ol]:pl-5
         [&_ol_ol_ol]:list-[lower-roman] [&_ol_ol_ol]:pl-5
  ">
    <div class="md:pl-5" set:html={car.content.rendered} />

      <Separator className="h-px bg-white/50" />
      <div class="md:pl-5">
        <h3 class="mb-3 font-bold text-lg">{options.additional_service.additional_service_title}</h3>
        <div set:html={options.additional_service.additional_service_items} />
      </div>
  </div>
</div>
