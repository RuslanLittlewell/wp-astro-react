---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/layouts/Container.astro";
import FuzzyText from "@/components/Shared/FuzzyText";
import { Button } from "@/components/ui/button";
---

<BaseLayout
  title="Страница не найдена — 404 | Car1.by"
  description="Такой страницы нет. Вернитесь на главную или посмотрите весь автопарк."
  className="scrolled"
>
  <Container class="flex flex-col items-center justify-center text-center py-32 min-h-[70vh]">
    <FuzzyText
      text="404"
      fontSize="clamp(5rem, 20vw, 12rem)"
      fontWeight={900}
      color="#37474F"
      baseIntensity={0.18}
      hoverIntensity={0.5}
      client:only="react"
    />
    <h1 class="text-2xl md:text-3xl font-bold text-denim-900 mt-8">
      Страница не найдена
    </h1>
    <p class="text-denim-700 mt-3 max-w-md">
      Возможно, страница была удалена или вы перешли по неверной ссылке.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 mt-8">
      <Button asChild size="lg">
        <a
          href="/"
          class="text-white px-6 py-4 rounded-md bg-denim-300 hover:bg-denim-300/80 block w-max mx-auto"
          >На главную</a
        >
      </Button>
      <Button asChild size="lg" variant="outline">
        <a
          href="/cars/"
          class="px-6 py-4 rounded-md border border-denim-300 text-denim-300 hover:bg-denim-300/10 block w-max mx-auto"
          >Весь автопарк</a
        >
      </Button>
    </div>
  </Container>
</BaseLayout>
